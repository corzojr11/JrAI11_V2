# ============================================
# JrAI11 — Variables de entorno (EJEMPLO)
# Copia este archivo como .env y rellena tus keys
# ============================================

# --- Entorno ---
APP_ENV=development
FRONTEND_ORIGINS=http://localhost:3000
COOKIE_SAMESITE=lax

# --- Token de seguridad para crear primer admin ---
BOOTSTRAP_TOKEN=tu_token_seguro_aqui

# --- JWT ---
JWT_SECRET_KEY=tu_clave_jwt_larga_y_segura_aqui

# --- The Odds API ---
ODDS_API_KEY=tu_api_key_aqui

# --- API-Football ---
API_FOOTBALL_KEY=tu_api_key_aqui

# --- Google AI Studio (Gemini) ---
GOOGLE_API_KEY=tu_api_key_aqui

# --- Groq ---
GROQ_API_KEY=tu_api_key_aqui

# --- OpenRouter ---
OPENROUTER_API_KEY=tu_api_key_aqui

# --- SambaNova ---
SAMBANOVA_API_KEY=tu_api_key_aqui

# --- Telegram (opcional) ---
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# --- Admin (opcional) ---
ADMIN_PASSWORD=tu_password_aqui
